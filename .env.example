PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL (Neon, Supabase, RDS, local, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/juga_en_grande

# Sin SSL local: DATABASE_SSL=false
# Si tu proveedor usa certificados no estándar: PG_SSL_REJECT_UNAUTHORIZED=false

# Mercado Pago Developers > Tu aplicación > Credenciales
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx

# PayPal Developer > Apps & Credentials
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_ENV=sandbox

# Fallback si no responde la cotizacion automatica USD/ARS
USD_ARS_RATE=1400

# Email transaccional por SMTP. Para Gmail usar una contrasena de aplicacion.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=rodrigocchinexx@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Juga en Grande <rodrigocchinexx@gmail.com>"
EMAIL_REPLY_TO=rodrigocchinexx@gmail.com

# Panel admin: usuario y contraseña (obligatorios para iniciar sesión)
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Firma de cookies de sesión admin; obligatorio en producción (NODE_ENV=production o Vercel)
SESSION_SECRET=cambiar-este-secreto-largo
