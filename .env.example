PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL (Neon, Supabase, RDS, local, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/juga_en_grande

# Sin SSL local: DATABASE_SSL=false
# Si tu proveedor usa certificados no estándar: PG_SSL_REJECT_UNAUTHORIZED=false

# Mercado Pago Developers > Tu aplicación > Credenciales
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx

# Panel admin: usuario y contraseña (obligatorios para iniciar sesión)
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Firma de cookies de sesión admin; obligatorio en producción (NODE_ENV=production o Vercel)
SESSION_SECRET=cambiar-este-secreto-largo
